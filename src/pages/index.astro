---
import BaseLayout from "@/components/layout/BaseLayout.astro";
---

<BaseLayout>
  <main class="flex min-h-screen items-center justify-center px-6 text-center">
    <section class="max-w-3xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.35em] text-[var(--gold)]">
        Portfolio Reel · Day 1
      </p>

      <h1 class="font-serif text-5xl font-bold text-[var(--cream)] md:text-7xl">
        Nur Junaina
      </h1>

      <p class="mt-6 text-lg text-[color:oklch(0.92_0.03_80_/_70%)]">
        Cinematic portfolio foundation is ready. Full film design starts on Day 2.
      </p>
    </section>
  </main>
</BaseLayout>