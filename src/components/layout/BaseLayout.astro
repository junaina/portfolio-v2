---
import FloatingAssistant from "@/components/assistant/FloatingAssistant";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Nur Junaina — Software Engineer & Creative Technologist",
  description = "A cinematic portfolio by Nur Junaina, software engineer and creative technologist building elegant, performant web systems.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Playfair+Display:wght@600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
    <FloatingAssistant client:idle />
  </body>
</html>
