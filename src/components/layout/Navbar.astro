---
const navItems = [
  { label: "Intro", href: "#intro" },
  { label: "Projects", href: "#projects" },
  { label: "Skills", href: "#skills" },
  { label: "Contact", href: "#contact" },
] as const;
---

<header
  class="border-gold/10 bg-background/82 fixed top-0 left-0 z-50 w-full border-b backdrop-blur-xl"
>
  <nav class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-6 md:px-8">
    <a href="#intro" class="group flex items-center gap-3" aria-label="Go to intro">
      <span class="text-gold font-mono text-xs tracking-[0.35em] uppercase">
        SC. 00
      </span>
      <span class="bg-gold/30 h-4 w-px"></span>
      <span
        class="font-display text-cream group-hover:text-gold text-xl font-black tracking-wide transition-colors"
      >
        NJ
      </span>
    </a>

    <div class="hidden items-center gap-9 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-cream-muted hover:text-cream text-sm font-medium transition-colors"
          >
            {item.label}
          </a>
        ))
      }

      <button
        type="button"
        data-open-assistant
        class="text-cream-muted hover:text-cream text-sm font-medium transition-colors"
      >
        Ask Me
      </button>

      <a
        href="/cv/Nur-Junaina-CV.pdf"
        class="border-gold/50 text-gold hover:border-gold hover:bg-gold hover:text-background rounded-sm border px-5 py-2 font-mono text-xs tracking-[0.35em] uppercase transition-colors"
      >
        CV
      </a>
    </div>

    <div class="flex items-center gap-3 md:hidden">
      <button
        type="button"
        data-open-assistant
        class="border-gold/40 text-gold rounded-sm border px-3 py-2 font-mono text-[10px] tracking-[0.24em] uppercase"
      >
        Ask
      </button>

      <a
        href="/cv/Nur-Junaina-CV.pdf"
        class="border-gold/40 text-gold rounded-sm border px-3 py-2 font-mono text-[10px] tracking-[0.24em] uppercase"
      >
        CV
      </a>
    </div>
  </nav>
</header>

<script>
  const assistantButtons = document.querySelectorAll("[data-open-assistant]");

  assistantButtons.forEach((button) => {
    button.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("open-assistant"));
    });
  });
</script>
