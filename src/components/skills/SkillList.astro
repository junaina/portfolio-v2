---
type Props = {
  items: readonly string[];
};

const { items } = Astro.props;
---

<ul class="mt-8 space-y-3">
  {
    items.map((item) => (
      <li class="group border-gold/10 flex items-center gap-3 border-b pb-3">
        <span class="text-gold font-mono text-sm transition-transform group-hover:translate-x-1">
          ›
        </span>
        <span class="text-cream-muted group-hover:text-cream font-mono text-sm font-medium transition-colors">
          {item}
        </span>
      </li>
    ))
  }
</ul>
