---
import SkillList from "@/components/skills/SkillList.astro";
import type { SkillGroup } from "@/data/skills";

type Props = {
  group: SkillGroup;
};

const { group } = Astro.props;
---

<article
  data-motion-card
  class="border-gold/15 bg-card relative overflow-visible rounded-lg border p-7"
>
  {
    group.label && (
      <div class="bg-primary text-primary-foreground absolute top-0 left-1/2 z-20 -translate-x-1/2 -translate-y-1/2 rounded-sm px-4 py-2 font-mono text-[0.62rem] font-bold tracking-[0.22em] uppercase shadow-lg">
        {group.label}
      </div>
    )
  }

  <div
    class="border-gold/25 text-gold/45 absolute top-7 right-7 flex h-10 w-10 items-center justify-center rounded-full border"
  >
    ✶
  </div>

  <p class="text-cream-muted/55 font-mono text-[0.68rem] tracking-[0.28em] uppercase">
    ({group.subtitle})
  </p>

  <h3 class="text-gold mt-4 font-serif text-3xl tracking-wide uppercase md:text-4xl">
    {group.title}
  </h3>

  <SkillList items={group.items} />
</article>
