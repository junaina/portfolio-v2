---
import SceneLabel from "@/components/film/SceneLabel.astro";
---

<section
  id="contact"
  class="border-gold/10 bg-background border-t px-6 py-28 md:px-8 md:py-36"
>
  <div class="mx-auto max-w-7xl">
    <SceneLabel scene="SC. 04" label="Closing Credits" />

    <div class="mt-16 max-w-4xl">
      <h2 class="text-cream font-serif text-5xl leading-tight italic md:text-7xl">
        Let&apos;s make something worth watching.
      </h2>

      <p class="text-cream-muted mt-6 max-w-2xl text-lg leading-8">
        Contact section comes on Day 4. This placeholder keeps the page anchors working
        while the portfolio structure is being built.
      </p>
    </div>
  </div>
</section>
