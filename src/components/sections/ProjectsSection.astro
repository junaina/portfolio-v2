---
import SceneLabel from "@/components/film/SceneLabel.astro";
import ProjectGrid from "@/components/project/ProjectGrid.astro";
---

<section
  id="projects"
  class="border-gold/10 bg-background relative overflow-hidden border-t px-6 py-28 md:px-8 md:py-36"
>
  <div class="relative z-10 mx-auto max-w-7xl">
    <SceneLabel scene="SC. 04" label="Featured Projects" />

    <div class="mt-16 flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <h2
        class="font-display text-[clamp(4rem,10vw,9.5rem)] leading-[0.78] font-black tracking-[-0.065em] uppercase"
      >
        <span class="text-cream block">Featured</span>
        <span class="text-cream/30 block">Projects</span>
      </h2>

      <p class="text-gold-muted font-mono text-xs tracking-[0.42em] uppercase">
        Selected Works (2022–2026)
      </p>
    </div>

    <div class="mt-16">
      <ProjectGrid />
    </div>
  </div>
</section>
