---
import MarqueeFrame from "@/components/film/MarqueeFrame.astro";
---

<section
  id="intro"
  class="hero-curtain film-grain film-vignette film-dust relative min-h-screen overflow-hidden pt-[72px]"
>
  <div class="spotlight absolute inset-x-0 top-0 h-[420px]"></div>

  <div
    class="border-gold/10 bg-burgundy/20 absolute top-1/2 left-0 hidden h-48 w-48 -translate-x-1/3 -translate-y-1/2 rounded-full border blur-2xl md:block"
  >
  </div>

  <div
    class="border-gold/10 absolute right-8 bottom-8 hidden h-64 w-64 rounded-full border bg-black/20 blur-3xl md:block"
  >
  </div>

  <div
    class="relative z-10 mx-auto flex min-h-[calc(100vh-72px)] max-w-7xl items-center px-6 py-14 md:px-8"
  >
    <div class="mx-auto w-full text-center">
      <div
        class="text-gold-muted mb-8 flex items-center justify-center gap-5 font-mono text-xs tracking-[0.42em] uppercase"
      >
        <span class="bg-gold/30 hidden h-px w-16 sm:block"></span>
        <span>Portfolio Reel · 2024</span>
        <span class="bg-gold/30 hidden h-px w-16 sm:block"></span>
      </div>

      <MarqueeFrame>
        <p
          class="text-gold-muted mb-8 font-mono text-[0.65rem] tracking-[0.42em] uppercase md:text-xs"
        >
          Scene 01 · Take 01 · Starring
        </p>

        <h1 class="leading-[0.82] tracking-[-0.07em]">
          <span
            class="font-display text-cream block text-[clamp(4.5rem,13vw,11rem)] font-black uppercase"
          >
            Nur
          </span>

          <span
            class="text-gold block translate-y-2 font-serif text-[clamp(4rem,12vw,10rem)] font-normal tracking-[-0.055em] italic md:translate-y-4"
          >
            Junaina
          </span>
        </h1>
      </MarqueeFrame>

      <div class="mx-auto mt-14 max-w-3xl">
        <p class="text-cream font-serif text-3xl leading-tight italic md:text-5xl">
          Software Engineer · Creative Technologist
        </p>

        <p class="text-cream-muted mx-auto mt-6 max-w-2xl text-base leading-8 md:text-lg">
          Translating complex problems into elegant, performant systems. Every line of
          code is a frame; every deployment, a premiere.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#projects"
            class="bg-gold text-background inline-flex min-h-14 items-center justify-center px-9 font-mono text-xs tracking-[0.32em] uppercase transition-transform hover:-translate-y-0.5"
          >
            🎬 View Projects
          </a>

          <a
            href="#contact"
            class="border-cream/25 text-cream hover:border-gold hover:text-gold inline-flex min-h-14 items-center justify-center border px-9 font-mono text-xs tracking-[0.32em] uppercase transition-colors"
          >
            Get in Touch
          </a>
        </div>

        <div
          class="text-cream-muted/50 mt-16 font-mono text-[0.65rem] tracking-[0.45em] uppercase"
        >
          Scroll
          <div class="bg-gold/30 mx-auto mt-4 h-12 w-px"></div>
        </div>
      </div>
    </div>
  </div>
</section>
