---
import SceneLabel from "@/components/film/SceneLabel.astro";
import SkillCard from "@/components/skills/SkillCard.astro";
import { skillGroups } from "@/data/skills";
---

<section
  id="skills"
  class="border-gold/10 bg-background relative overflow-hidden border-t px-6 py-28 md:px-8 md:py-36"
>
  <div
    class="bg-burgundy/20 pointer-events-none absolute top-0 right-0 h-96 w-96 translate-x-1/3 rounded-full blur-3xl"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <SceneLabel scene="SC. 02" label="Production Toolkit" />

    <div class="mt-16">
      <h2
        class="font-display text-[clamp(4rem,11vw,10rem)] leading-[0.78] font-black tracking-[-0.065em] uppercase"
      >
        <span class="text-cream block">Technical</span>
        <span class="text-cream/30 block">Skills</span>
      </h2>
    </div>

    <div class="mt-20 grid gap-x-7 gap-y-12 md:grid-cols-3">
      {skillGroups.map((group) => <SkillCard group={group} />)}
    </div>
  </div>
</section>
