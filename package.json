{
  "name": "portfolio-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "vercel:pull": "vercel pull --yes --environment=preview",
    "vercel:build": "vercel build",
    "verify": "npm run lint && npm run check && npm run typecheck && npm run build",
    "verify:vercel": "npm run verify && npm run vercel:pull && npm run vercel:build",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/vercel": "^11.0.1",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq-sdk": "^1.3.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vercel": "^54.15.1"
  }
}
